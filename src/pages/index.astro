---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Problems from '../components/Problems.astro';
import Services from '../components/Services.astro';
import Benefits from '../components/Benefits.astro';
import Portfolio from '../components/Portfolio.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import ExitPopup from '../components/ExitPopup.astro';
import '../styles/global.css';
---

<Layout title="Website Bisnes Anda Nampak 'Biasa-Biasa' Atau 'Luar Biasa'? | Transformasi Digital SME Malaysia">
  <!-- Preloader -->
  <section class="preloader" id="preloader">
    <div class="spinner"></div>
  </section>
  
  <Navbar />
  
  <main id="main-content" role="main">
    <Hero />
    <Problems />
    <Services />
    <Benefits />
    <Portfolio />
    <Testimonials />
    <FAQ />
    <Contact />
  </main>
  
  <Footer />
  <ExitPopup />
  
  <!-- Structured Data -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "WebDevMY",
    "description": "Web development services for Malaysian SMEs. Custom websites, landing pages, and AI integration to boost business credibility and sales.",
    "url": "https://webdevmy.com",
    "telephone": "+60-13-879-9702",
    "email": "hello@webdevmy.com",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "MY",
      "addressRegion": "Malaysia"
    },
    "openingHours": "Mo-Fr 09:00-18:00",
    "priceRange": "RM 1,299 - RM 4,999",
    "serviceArea": {
      "@type": "Country",
      "name": "Malaysia"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "50"
    }
  }
  </script>
  
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Bagaimana landing page homestay boleh tarik pelawat antarabangsa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Gunakan storytelling budaya, visual immersive, dan CTA multilingual."
        }
      },
      {
        "@type": "Question",
        "name": "Berapa timeline biasa untuk siap?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Landing page siap dalam 10-14 hari manakala corporate site dengan integrasi AI mengambil masa 4-6 minggu."
        }
      },
      {
        "@type": "Question",
        "name": "Berapa anggaran kos projek?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Landing page bermula RM1,299, website SME RM2,999 dan projek AI atau automation dari RM4,999."
        }
      }
    ]
  }
  </script>
  
  <!-- Hide preloader after load -->
  <script is:inline>
    window.addEventListener('load', () => {
      const preloader = document.getElementById('preloader');
      if (preloader) {
        preloader.style.opacity = '0';
        setTimeout(() => preloader.style.display = 'none', 300);
      }
    });
    
    // CTA tracking
    document.querySelectorAll('[data-track="cta"]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'cta_click', {
            event_category: 'engagement',
            event_label: btn.getAttribute('href') || 'cta'
          });
        }
      });
    });
  </script>
</Layout>
