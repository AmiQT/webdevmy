---
import { projects } from '../data/portfolio';
---

<section id="portfolio" class="section-padding bg-foreground text-background">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 md:mb-16">
      <span class="inline-block text-sm font-semibold text-secondary mb-4 tracking-wider uppercase">
        Portfolio
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Transformasi Yang Kami{' '}
        <span class="text-secondary">Telah Lakukan</span>
      </h2>
      <p class="text-lg text-background/70">
        Lihat bagaimana kami membantu bisnes lain berjaya dengan solusi digital.
      </p>
    </div>
    
    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project, index) => (
        <div 
          class="group bg-background/5 backdrop-blur-sm rounded-2xl overflow-hidden border border-background/10 hover:border-secondary/50 hover:-translate-y-2 transition-all duration-500 animate-rotate-in shadow-lg hover:shadow-secondary/20"
          style={`animation-delay: ${index * 150}ms`}
        >
          <!-- Image -->
          <div class="relative overflow-hidden aspect-video bg-gradient-to-br from-primary/20 to-secondary/20">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              loading="lazy"
              onerror="this.style.display='none'"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
              <span class="text-secondary font-bold text-sm">Lihat Projek →</span>
            </div>
          </div>
          
          <!-- Content -->
          <div class="p-6">
            <span class="inline-block text-xs font-semibold text-secondary mb-2">{project.category}</span>
            <h3 class="text-xl font-bold mb-2 group-hover:text-secondary transition-colors">{project.title}</h3>
            <p class="text-background/60 text-sm mb-4">{project.description}</p>
            
            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="text-xs px-2 py-1 rounded-full bg-background/10 text-background/70">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <p class="text-background/60 text-sm mb-4">Nak lihat portfolio yang lebih detail?</p>
      <a 
        href="#hubungi"
        class="inline-flex items-center gap-2 bg-secondary text-secondary-foreground px-6 py-3 rounded-lg font-semibold hover:bg-secondary/90 transition-colors"
      >
        Hubungi Kami Untuk Portfolio Lengkap
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
