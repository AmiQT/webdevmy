---
import { projects } from '../data/portfolio';
---

<section id="portfolio" class="section-padding bg-muted/30">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 md:mb-16">
      <span class="inline-block text-sm font-semibold text-secondary mb-4 tracking-wider uppercase">
        Portfolio
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Projek Yang Telah{' '}
        <span class="gradient-text">Kami Bina</span>
      </h2>
      <p class="text-lg text-muted-foreground">
        Dari AI systems hingga cloud infrastructure - setiap projek ada cerita teknikal tersendiri.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project, index) => (
        <div
          class="group bg-card border border-border rounded-2xl p-6 hover:border-secondary/40 hover:bg-card/80 transition-all duration-300 flex flex-col gap-4"
        >
          <!-- Top Row: Category + Index -->
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold text-secondary tracking-wider uppercase">
              {project.category}
            </span>
            <span class="text-muted-foreground/40 text-xs font-mono">
              {String(index + 1).padStart(2, '0')}
            </span>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold text-foreground group-hover:text-secondary transition-colors duration-300 leading-snug">
            {project.title}
          </h3>

          <!-- Description -->
          <p class="text-muted-foreground text-sm leading-relaxed flex-1">
            {project.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 pt-2 border-t border-border">
            {project.tags.map(tag => (
              <span class="text-xs px-2 py-1 rounded-md bg-muted text-muted-foreground group-hover:text-secondary/80 transition-colors duration-300">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <p class="text-muted-foreground text-sm mb-4">Nak tahu lebih lanjut tentang mana-mana projek?</p>
      <a
        href="#hubungi"
        class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors"
      >
        Hubungi Kami
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
