---
const benefits = [
  'Custom Design yang Unik',
  'Mobile-Friendly 100%',
  'SEO Optimized',
  '24/7 Support',
];
---

<div 
  id="exitIntentPopup" 
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  role="dialog" 
  aria-modal="true" 
  aria-hidden="true"
>
  <!-- Overlay -->
  <div class="absolute inset-0 bg-background/80 backdrop-blur-sm" id="popupOverlay"></div>
  
  <!-- Content -->
  <div class="relative bg-card border border-border rounded-xl max-w-md w-full p-6 md:p-8 text-center transform scale-95 opacity-0 transition-all duration-300 shadow-2xl" id="popupContent">
    <!-- Close button -->
    <button 
      class="absolute top-3 right-3 text-muted-foreground hover:text-foreground transition-colors p-1 rounded-full hover:bg-muted"
      id="popupClose"
      aria-label="Close popup"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <h3 class="text-2xl font-bold text-foreground mb-2">Jangan Pergi Dulu!</h3>
    <p class="text-muted-foreground mb-4">Dapatkan <span class="text-primary font-semibold">DISKAUN 20%</span> untuk website pertama anda!</p>
    
    <!-- Discount badge -->
    <div class="inline-flex items-center gap-2 bg-gradient-to-r from-primary to-secondary text-white text-2xl font-bold px-6 py-3 rounded-full mb-6 shadow-lg">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      20% OFF
    </div>
    
    <h4 class="text-lg font-semibold text-foreground mb-4">Website Professional untuk Bisnes Anda</h4>
    
    <!-- Benefits list -->
    <ul class="text-left space-y-3 mb-6">
      {benefits.map(benefit => (
        <li class="flex items-center gap-3 text-foreground">
          <svg class="w-5 h-5 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>{benefit}</span>
        </li>
      ))}
    </ul>
    
    <!-- CTA Button -->
    <a 
      href="https://wa.me/60138799702?text=Hi,%20saya%20berminat%20dengan%20DISKAUN%2020%%20untuk%20website%20pertama%20saya.%20Boleh%20kita%20bincang?" 
      target="_blank" 
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 w-full bg-secondary hover:bg-secondary/90 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
      data-track="cta"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Dapatkan Diskaun Sekarang!
    </a>
    
    <p class="text-xs text-muted-foreground mt-4">Tawaran sah sehingga akhir bulan ini sahaja!</p>
  </div>
</div>

<script>
  const popup = document.getElementById('exitIntentPopup');
  const popupContent = document.getElementById('popupContent');
  const popupClose = document.getElementById('popupClose');
  const popupOverlay = document.getElementById('popupOverlay');
  
  let hasShown = false;
  
  const showPopup = () => {
    if (hasShown) return;
    hasShown = true;
    popup?.classList.remove('hidden');
    popup?.classList.add('flex');
    setTimeout(() => {
      popupContent?.classList.remove('scale-95', 'opacity-0');
      popupContent?.classList.add('scale-100', 'opacity-100');
    }, 10);
  };
  
  const hidePopup = () => {
    popupContent?.classList.add('scale-95', 'opacity-0');
    popupContent?.classList.remove('scale-100', 'opacity-100');
    setTimeout(() => {
      popup?.classList.add('hidden');
      popup?.classList.remove('flex');
    }, 300);
  };
  
  // Exit intent detection
  document.addEventListener('mouseout', (e) => {
    if (e.clientY < 10) showPopup();
  });
  
  popupClose?.addEventListener('click', hidePopup);
  popupOverlay?.addEventListener('click', hidePopup);
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hidePopup();
  });
</script>
