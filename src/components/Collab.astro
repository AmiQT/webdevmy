---
const collabTypes = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v3M21 17a2 2 0 01-2 2H9" /></svg>`,
    title: "Projek Freelance",
    badge: "Hire Me",
    badgeClass: "bg-primary/10 text-primary border border-primary/20",
    desc: "Ada projek website atau web app yang nak siapkan? Boleh engage secara freelance — solo atau support team sedia ada.",
    points: ["Web development (Astro, Next.js, React)", "DevOps setup & deployment automation", "CI/CD pipeline & monitoring", "AI integration & chatbot"],
    cta: "Bincang Projek",
    ctaClass: "bg-primary text-primary-foreground hover:bg-primary/90",
    waText: "Hi,%20saya%20berminat%20nak%20engage%20untuk%20projek%20freelance.%20Boleh%20kita%20bincang%3F",
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    title: "Kolaborasi Teknikal",
    badge: "Let's Build",
    badgeClass: "bg-secondary/10 text-secondary border border-secondary/20",
    desc: "Kau developer ke, startup ke, atau ada idea gila nak execute? Jom kita bina sama-sama — open source, side project, atau product baru.",
    points: ["Co-build web app atau SaaS", "Contribute to open source", "Technical review & architecture", "Startup tech partnership"],
    cta: "Jom Collab",
    ctaClass: "bg-secondary text-secondary-foreground hover:bg-secondary/90",
    waText: "Hi,%20saya%20berminat%20untuk%20kolaborasi%20teknikal.%20Ada%20idea%20nak%20bincang!",
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    title: "Part-time / Contract",
    badge: "Available",
    badgeClass: "bg-emerald-500/10 text-emerald-600 border border-emerald-500/20",
    desc: "Perlu developer on-demand atau nak extend team dengan contract basis? Boleh accommodate schedule flexible — remote friendly.",
    points: ["Contract basis (1–6 bulan)", "Remote / hybrid", "DevOps & web full-stack", "Technical support & maintenance"],
    cta: "Tanya Availability",
    ctaClass: "bg-foreground text-background hover:bg-foreground/90",
    waText: "Hi,%20saya%20berminat%20nak%20tanya%20tentang%20availability%20untuk%20part-time%2Fcontract%20basis.",
  },
];
---

<section id="kolaborasi" class="section-padding bg-muted/40">
  <div class="container mx-auto px-4">

    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-14 animate-fade-in-up">
      <span class="inline-block text-sm font-semibold text-secondary mb-4 tracking-wider uppercase">
        Kolaborasi & Freelance
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-5">
        Ada Idea? Jom{' '}
        <span class="gradient-text">Bina Sama-sama</span>
      </h2>
      <p class="text-lg text-muted-foreground">
        Bukan sekadar agency — aku juga available untuk freelance, collab teknikal, dan contract work. Reach out terus!
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      {collabTypes.map((item, i) => (
        <div class={`bg-card rounded-2xl p-7 shadow-sm border border-border flex flex-col gap-5 hover:shadow-md hover:-translate-y-1 transition-all duration-300 animate-slide-in-left`} style={`animation-delay: ${i * 100}ms`}>

          <!-- Icon + Badge -->
          <div class="flex items-start justify-between">
            <div class="p-3 bg-muted rounded-xl text-primary">
              <Fragment set:html={item.icon} />
            </div>
            <span class={`text-xs font-semibold px-3 py-1 rounded-full ${item.badgeClass}`}>
              {item.badge}
            </span>
          </div>

          <!-- Title + Desc -->
          <div>
            <h3 class="text-xl font-bold mb-2">{item.title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">{item.desc}</p>
          </div>

          <!-- Points -->
          <ul class="space-y-2 flex-1">
            {item.points.map(pt => (
              <li class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                {pt}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={`https://wa.me/60138799702?text=${item.waText}`}
            target="_blank"
            rel="noopener noreferrer"
            class={`inline-flex items-center justify-center gap-2 w-full py-3 rounded-lg font-semibold text-sm transition-all hover:scale-[1.02] ${item.ctaClass}`}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {item.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Bottom Note -->
    <div class="text-center">
      <p class="text-muted-foreground text-sm">
        Tak pasti nak pilih yang mana?{' '}
        <a
          href="https://wa.me/60138799702?text=Hi,%20saya%20nak%20tanya%20tentang%20peluang%20kolaborasi%20atau%20freelance.%20Boleh%20kita%20bincang%3F"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary font-semibold hover:underline"
        >
          WhatsApp je terus
        </a>
        {' '}— aku akan guide!
      </p>
    </div>

  </div>
</section>
