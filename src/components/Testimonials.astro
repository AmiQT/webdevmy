---
const testimonials = [
  {
    quote: 'Website baru ni memang game-changer! Sales saya naik 30% dalam masa sebulan. Pelanggan sekarang lebih percaya dengan bisnes saya.',
    name: 'Pn. Siti',
    role: 'Owner Butik Online',
    rating: 5,
  },
  {
    quote: 'Sistem AI chatbot tu jimatkan banyak masa team saya. Pelanggan dapat jawapan cepat, kita fokus pada kerja lain. Highly recommended!',
    name: 'En. Azim',
    role: 'Pengurus Agensi',
    rating: 5,
  },
  {
    quote: 'Landing page yang mereka buat untuk kempen saya memang power! Conversion rate naik gila-gila. ROI dalam 2 minggu je!',
    name: 'En. Rahman',
    role: 'Restoran Owner',
    rating: 5,
  },
];
---

<section id="testimoni" class="section-padding bg-muted/30">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-primary mb-4 tracking-wider uppercase">
        Testimoni
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Apa Kata{' '}
        <span class="gradient-text">Pelanggan Kami</span>?
      </h2>
      <p class="text-lg text-muted-foreground">
        Dengar sendiri pengalaman mereka yang telah transform bisnes dengan kami.
      </p>
    </div>
    
    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <div 
          class="bg-card rounded-2xl p-8 shadow-sm border hover:shadow-2xl hover:scale-105 transition-all duration-500 animate-slide-in-right"
          style={`animation-delay: ${index * 150}ms`}
        >
          <!-- Quote Icon -->
          <div class="mb-6">
            <svg class="w-10 h-10 text-primary/20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
          </div>
          
          <!-- Rating -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          
          <!-- Quote -->
          <p class="text-foreground mb-6 leading-relaxed">"{testimonial.quote}"</p>
          
          <!-- Author -->
          <div class="flex items-center gap-4 pt-6 border-t">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-primary font-bold text-lg">{testimonial.name.charAt(0)}</span>
            </div>
            <div>
              <strong class="block text-foreground">{testimonial.name}</strong>
              <span class="text-muted-foreground text-sm">{testimonial.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
