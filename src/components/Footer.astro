---
const services = ['Custom Website', 'Landing Page', 'Corporate Website', 'E-commerce', 'AI Integration'];
const quickLinks = [
  { href: '#masalah', label: 'Masalah' },
  { href: '#solusi', label: 'Solusi' },
  { href: '#portfolio', label: 'Portfolio' },
  { href: '#testimoni', label: 'Testimoni' },
  { href: '#hubungi', label: 'Hubungi' },
];
---

<footer class="bg-foreground text-background py-16">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-12">
      <!-- Brand -->
      <div class="sm:col-span-2">
        <a href="/" class="text-2xl font-heading font-bold text-secondary mb-4 block">
          WebDevMY
        </a>
        <p class="text-background/70 mb-6 max-w-md text-sm md:text-base">
          Transformasi digital untuk SME Malaysia. Website custom, landing page berkesan, dan integrasi AI untuk tingkatkan jualan & kredibiliti bisnes anda.
        </p>
        <div class="flex gap-4">
          <a 
            href="https://wa.me/60138799702" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="w-10 h-10 bg-background/10 rounded-full flex items-center justify-center hover:bg-secondary hover:scale-110 hover:rotate-12 transition-all duration-300"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <a 
            href="mailto:hello@webdevmy.com" 
            class="w-10 h-10 bg-background/10 rounded-full flex items-center justify-center hover:bg-secondary hover:scale-110 hover:rotate-12 transition-all duration-300"
            aria-label="Email"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Services -->
      <div>
        <h4 class="font-bold text-lg mb-4">Servis</h4>
        <ul class="space-y-3">
          {services.map(service => (
            <li>
              <a href="#solusi" class="text-background/70 hover:text-secondary hover:translate-x-1 inline-block transition-all duration-300 text-sm">
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h4 class="font-bold text-lg mb-4">Pautan</h4>
        <ul class="space-y-3">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-background/70 hover:text-secondary hover:translate-x-1 inline-block transition-all duration-300 text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="pt-8 border-t border-background/10 text-center">
      <p class="text-background/50 text-sm">
        © 2026 WebDevMY. Hak cipta terpelihara. | 
        <a href="https://amiqt.github.io/portfolio" target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors">
          Portfolio GitHub
        </a>
      </p>
    </div>
  </div>
</footer>

<!-- Back to Top Button -->
<button 
  id="backToTop" 
  class="fixed bottom-6 right-6 w-12 h-12 bg-primary text-primary-foreground rounded-full shadow-lg opacity-0 invisible transition-all duration-300 hover:bg-primary/90 z-50"
  aria-label="Back to top"
>
  <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
  </svg>
</button>

<script>
  const backToTop = document.getElementById('backToTop');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      backToTop?.classList.remove('opacity-0', 'invisible');
      backToTop?.classList.add('opacity-100', 'visible');
    } else {
      backToTop?.classList.add('opacity-0', 'invisible');
      backToTop?.classList.remove('opacity-100', 'visible');
    }
  });
  
  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
