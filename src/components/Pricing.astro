---
const plans = [
  {
    name: 'Starter',
    subtitle: 'Sesuai untuk bisnes baru',
    price: 'RM 1,299',
    priceNote: 'sekali bayar',
    popular: false,
    color: 'border-muted',
    features: [
      'Landing Page 1 halaman',
      'Mobile Responsive',
      'SEO Basic (On-page)',
      'Borang Hubungi + WhatsApp CTA',
      'Google Analytics',
      'Domain Setup',
      'Siap dalam 10-14 hari',
      '30 hari support percuma',
    ],
    cta: 'Mula Dengan Starter',
    waMessage: 'Hi, saya berminat dengan pakej Starter (RM 1,299). Boleh kita bincang?',
  },
  {
    name: 'Business',
    subtitle: 'Pilihan paling popular',
    price: 'RM 2,999',
    priceNote: 'sekali bayar',
    popular: true,
    color: 'border-primary',
    features: [
      'Website Custom 5-8 halaman',
      'Mobile Responsive + Fast Loading',
      'SEO On-page + Technical',
      'CMS WordPress (edit sendiri)',
      'Blog & Portfolio section',
      'Google Analytics + Search Console',
      'Domain + Hosting 1 tahun',
      'Siap dalam 3-4 minggu',
      '60 hari support percuma',
      'Training video CMS',
    ],
    cta: 'Pilih Business',
    waMessage: 'Hi, saya berminat dengan pakej Business (RM 2,999). Boleh kita bincang?',
  },
  {
    name: 'Enterprise',
    subtitle: 'Untuk bisnes yang serius',
    price: 'RM 4,999',
    priceNote: 'bermula dari',
    popular: false,
    color: 'border-secondary',
    features: [
      'E-commerce / Corporate penuh',
      'AI Chatbot integration',
      'Payment gateway (FPX, Visa, MC)',
      'Inventory & Order management',
      'Custom dashboard admin',
      'Advanced SEO + Schema markup',
      'Email marketing integration',
      'Siap dalam 4-6 minggu',
      '90 hari support percuma',
      'Dedicated project manager',
    ],
    cta: 'Bincang Enterprise',
    waMessage: 'Hi, saya berminat dengan pakej Enterprise (dari RM 4,999). Boleh kita bincang?',
  },
];
---

<section id="harga" class="section-padding bg-muted/30">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 md:mb-16">
      <span class="inline-block text-sm font-semibold text-primary mb-4 tracking-wider uppercase">
        Pakej & Harga
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Pelaburan Yang{' '}
        <span class="gradient-text">Berbaloi Untuk Bisnes</span>
      </h2>
      <p class="text-lg text-muted-foreground px-4">
        Harga telus, tanpa hidden cost. Pilih pakej yang sesuai atau kami buat custom quote untuk anda.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 items-start">
      {plans.map((plan, index) => (
        <div
          class={`relative bg-card rounded-2xl border-2 shadow-sm transition-all duration-500 animate-bounce-in overflow-hidden ${plan.popular ? 'border-primary shadow-2xl shadow-primary/10 md:-mt-4 md:mb-4' : plan.color}`}
          style={`animation-delay: ${index * 150}ms`}
        >
          {plan.popular && (
            <div class="bg-primary text-primary-foreground text-center text-sm font-bold py-2 tracking-wide">
              ⭐ PALING POPULAR
            </div>
          )}

          <div class="p-6 md:p-8">
            <!-- Plan Name -->
            <div class="mb-6">
              <h3 class="text-xl font-bold mb-1">{plan.name}</h3>
              <p class="text-sm text-muted-foreground">{plan.subtitle}</p>
            </div>

            <!-- Price -->
            <div class="mb-6 pb-6 border-b">
              <div class="flex items-end gap-2">
                <span class={`text-3xl md:text-4xl font-bold ${plan.popular ? 'text-primary' : 'text-foreground'}`}>
                  {plan.price}
                </span>
              </div>
              <p class="text-xs text-muted-foreground mt-1">{plan.priceNote}</p>
            </div>

            <!-- Features -->
            <ul class="space-y-3 mb-8">
              {plan.features.map(feature => (
                <li class="flex items-start gap-3 text-sm">
                  <svg class="w-4 h-4 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-muted-foreground">{feature}</span>
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href={`https://wa.me/60138799702?text=${encodeURIComponent(plan.waMessage)}`}
              target="_blank"
              rel="noopener noreferrer"
              class={`w-full inline-flex items-center justify-center gap-2 py-3 px-6 rounded-lg font-semibold transition-all hover:scale-105 ${plan.popular ? 'bg-primary text-primary-foreground hover:bg-primary/90 shadow-lg' : 'border-2 border-primary text-primary hover:bg-primary hover:text-primary-foreground'}`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Custom Quote Banner -->
    <div class="mt-12 bg-card border rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-xl font-bold mb-1">Ada keperluan khas?</h3>
        <p class="text-muted-foreground text-sm">Kami buat custom quote ikut scope projek anda. Tiada hidden cost, tiada surprise.</p>
      </div>
      <a
        href="https://wa.me/60138799702?text=Hi,%20saya%20nak%20minta%20custom%20quote%20untuk%20projek%20saya"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors whitespace-nowrap flex-shrink-0"
      >
        Minta Custom Quote
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
