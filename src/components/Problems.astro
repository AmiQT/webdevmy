---
const problems = [
  {
    title: 'Website Lapuk & Tak Profesional',
    description: 'First impression penting! Website lama buat pelanggan ragu-ragu.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
  },
  {
    title: 'Iklan Mahal, Conversion Rendah',
    description: 'Duit habis dekat ads tapi tak convert jadi sales.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    title: 'Staf Penat Jawab Soalan Sama',
    description: 'Masa terbuang jawab repeat questions setiap hari.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`,
  },
  {
    title: 'Website Tak Mesra Mobile',
    description: '70% traffic dari phone, tapi website slow & susah navigate.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>`,
  },
];
---

<section id="masalah" class="section-padding">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Content Side -->
      <div>
        <!-- Section Label -->
        <span class="inline-block text-sm font-semibold text-destructive mb-4 tracking-wider uppercase">
          Masalah Biasa
        </span>
        
        <!-- Heading -->
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
          Adakah Ini{' '}
          <span class="text-destructive">Cabaran</span>{' '}
          Bisnes Anda?
        </h2>
        
        <p class="text-lg text-muted-foreground mb-8">
          Ramai SME Malaysia hadapi masalah yang sama. Jangan risau, kami ada penyelesaiannya.
        </p>
        
        <!-- Problems List -->
        <div class="space-y-4">
          {problems.map((problem, index) => (
            <div 
              class="flex gap-4 p-4 rounded-xl bg-destructive/5 border border-destructive/10 hover:border-destructive/30 hover:scale-105 transition-all duration-300 animate-slide-in-left"
              style={`animation-delay: ${index * 150}ms`}
            >
              <div class="text-destructive flex-shrink-0" set:html={problem.icon} />
              <div>
                <h3 class="font-semibold text-foreground mb-1">{problem.title}</h3>
                <p class="text-sm text-muted-foreground">{problem.description}</p>
              </div>
            </div>
          ))}
        </div>
        
        <!-- CTA -->
        <div class="mt-8">
          <a 
            href="#solusi" 
            class="inline-flex items-center gap-2 text-primary font-semibold hover:gap-3 transition-all"
          >
            Lihat Penyelesaian Kami
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
