---

<section id="hubungi" class="section-padding gradient-primary text-primary-foreground">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-secondary mb-4 tracking-wider uppercase">
        Hubungi Kami
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Sedia Untuk Transform{' '}
        <span class="text-secondary">Bisnes Anda</span>?
      </h2>
      <p class="text-lg text-primary-foreground/80">
        Ada projek dalam fikiran? Dari AI integration hingga full system build - jom bincang.
      </p>
    </div>
    
    <div class="max-w-2xl mx-auto">
      <!-- CTA & Info -->
      <div>
        <!-- Quick CTA -->
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 md:p-8 mb-6 md:mb-8">
          <h3 class="text-xl md:text-2xl font-bold mb-4">Reach Out Terus</h3>
          <p class="text-primary-foreground/80 mb-6 text-sm md:text-base">
            WhatsApp untuk bincang scope, tech stack, atau timeline projek anda. Reply dalam 1-2 jam.
          </p>
          <a 
            href="https://wa.me/60138799702?text=Hi,%20saya%20berminat%20dengan%20servis%20web%20development%20anda.%20Boleh%20kita%20bincang?" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 md:gap-3 bg-white text-primary px-6 md:px-8 py-3 md:py-4 rounded-lg text-base md:text-lg font-semibold hover:bg-white/90 transition-all hover:scale-105 shadow-lg w-full md:w-auto"
          >
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span>WhatsApp Sekarang</span>
          </a>
          <p class="text-primary-foreground/60 text-sm mt-4 text-center md:text-left">013-879 9702</p>
        </div>
        
        <!-- What to Expect -->
        <div class="bg-white/5 rounded-2xl p-8">
          <h3 class="text-xl font-bold mb-6">Apa Yang Anda Akan Dapat:</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <strong>Discovery Call</strong>
                <p class="text-primary-foreground/70 text-sm">30 minit untuk faham scope dan keperluan teknikal</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <strong>Proposal & Sebut Harga</strong>
                <p class="text-primary-foreground/70 text-sm">Breakdown jelas tanpa hidden cost</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <strong>Timeline & Milestones</strong>
                <p class="text-primary-foreground/70 text-sm">Anda tahu bila dan apa yang akan siap</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
      
    </div>
  </div>
</section>
