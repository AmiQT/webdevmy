---
const benefits = [
  { title: 'Architecture Yang Betul', desc: 'Setiap sistem dibina dengan foundation yang kukuh - scalable, maintainable, dan production-ready dari hari pertama.' },
  { title: 'AI Yang Actually Work', desc: 'Bukan chatbot template. Agentic systems dengan tool calling, memory, dan RAG yang berfungsi dalam real-world scenarios.' },
  { title: 'Full Observability', desc: 'Logs, metrics, dan traces yang betul. Anda tahu apa yang berlaku dalam sistem anda pada setiap masa.' },
  { title: 'DevOps Best Practices', desc: 'CI/CD pipelines, containerization, dan IaC - pastikan deployment cepat, reliable, dan repeatable.' },
  { title: 'Transparent & Communicative', desc: 'Progress update yang jelas, documentation yang lengkap, dan anda sentiasa tahu status projek anda.' },
];

const stats = [
  { value: '10+', label: 'Tech Stacks' },
  { value: '3', label: 'Enterprise Clients' },
  { value: '100%', label: 'Production-Ready' },
  { value: '24/7', label: 'Support' },
];

const reasons = [
  'Pengalaman dengan enterprise & hackathon projects',
  'AI-first approach - bukan add-on selepas dah build',
  'Full-stack: frontend, backend, mobile, dan infra',
  'Code quality: tested, documented, dan maintainable',
  'Komunikasi responsif sepanjang projek',
];
---

<section class="section-padding bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-secondary mb-4 tracking-wider uppercase">
        Kenapa Pilih Kami
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Bukan Sekadar Deliver.{' '}
        <span class="text-secondary">Kami Bina Dengan Betul.</span>
      </h2>
      <p class="text-lg text-muted-foreground">
        Setiap keputusan teknikal ada sebab. Kami bina sistem yang anda boleh bangga dengan - dan yang boleh grow bersama bisnes anda.
      </p>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
      {stats.map((stat, index) => (
        <div
          class="text-center p-6 bg-primary/5 border border-primary/10 rounded-2xl hover:scale-110 transition-transform duration-300 animate-bounce-in"
          style={`animation-delay: ${index * 100}ms`}
        >
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">{stat.value}</div>
          <p class="text-muted-foreground text-sm">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Benefits & Reasons Grid -->
    <div class="grid lg:grid-cols-2 gap-8">
      <!-- Benefits -->
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8">
        <h3 class="text-2xl font-bold mb-8">Apa Yang Anda Dapat</h3>
        <div class="space-y-6">
          {benefits.map((benefit, index) => (
            <div
              class="flex gap-4 hover:translate-x-2 transition-transform duration-300 animate-slide-in-left"
              style={`animation-delay: ${index * 100}ms`}
            >
              <div class="w-12 h-12 rounded-xl bg-secondary/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-lg mb-1">{benefit.title}</h4>
                <p class="text-muted-foreground text-sm">{benefit.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Why Choose Us -->
      <div class="bg-primary/5 border border-primary/10 rounded-2xl p-8">
        <h3 class="text-2xl font-bold mb-8">Kenapa Kami?</h3>
        <ul class="space-y-4">
          {reasons.map((reason, index) => (
            <li
              class="flex items-center gap-3 animate-fade-in-up"
              style={`animation-delay: ${index * 100}ms`}
            >
              <svg class="w-6 h-6 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-muted-foreground">{reason}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 pt-6 border-t border-primary/10">
          <p class="text-muted-foreground mb-4">Sedia untuk bincang projek?</p>
          <a
            href="#hubungi"
            class="inline-flex items-center gap-2 bg-white text-primary px-6 py-3 rounded-lg font-semibold hover:bg-white/90 transition-colors"
          >
            Mulakan Sekarang
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
